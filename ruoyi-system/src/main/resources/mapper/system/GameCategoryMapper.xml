<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.GameCategoryMapper">

    <resultMap type="com.ruoyi.system.domain.GameCategory" id="GameCategoryResult">
        <id property="id" column="id"/>
        <result property="catName" column="cat_name"/>
        <result property="catIcon" column="cat_icon"/>
        <result property="sortNum" column="sort_num"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectGameCategoryList" parameterType="com.ruoyi.system.domain.GameCategory" resultMap="GameCategoryResult">
        select id, cat_name, cat_icon, sort_num, status, create_time
        from game_category
        <where>
            <if test="catName != null and catName != ''">
                AND cat_name like concat('%', #{catName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        order by sort_num asc
    </select>

    <select id="selectGameCategoryById" parameterType="Long" resultMap="GameCategoryResult">
        select id, cat_name, cat_icon, sort_num, status, create_time
        from game_category
        where id = #{id}
    </select>

    <insert id="insertGameCategory" parameterType="com.ruoyi.system.domain.GameCategory">
        INSERT INTO game_category (cat_name,cat_icon,sort_num,status,create_time)
        VALUES (#{catName},#{catIcon},#{sortNum},#{status},NOW())
    </insert>

    <update id="updateGameCategory" parameterType="com.ruoyi.system.domain.GameCategory">
        UPDATE game_category
        <set>
            <if test="catName != null">cat_name = #{catName},</if>
            <if test="catIcon != null">cat_icon = #{catIcon},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteGameCategoryByIds" parameterType="Long">
        DELETE FROM game_category
        WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>